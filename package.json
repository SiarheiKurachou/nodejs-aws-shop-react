    "@tanstack/react-query": "^5.100.10",
    "axios": "^1.16.1",
    "formik": "^2.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@playwright/experimental-ct-react": "^1.60.0",
    "@tanstack/react-query-devtools": "^5.100.10",
